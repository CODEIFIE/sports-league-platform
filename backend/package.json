{
  "name": "sports-league-backend",
  "version": "1.0.0",
  "description": "Sports League Management & Live Scoring Platform — API",
  "type": "module",
  "main": "dist/src/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "typecheck": "tsc --noEmit",
    "db:setup": "tsx scripts/setup-db.ts",
    "db:seed": "tsx scripts/seed.ts",
    "db:seed:real": "tsx scripts/seed-real.ts",
    "test:db": "tsx scripts/smoke-test.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.2.0",
    "mysql2": "^3.11.0",
    "pdfkit": "^0.15.0",
    "socket.io": "^4.7.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.4.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.14.0",
    "@types/pdfkit": "^0.13.4",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
